# ─── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (e.g. Postgres via Prisma / Neon / Supabase) ──────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lumaspace

# ─── Authentication (NextAuth.js / Auth.js) ─────────────────────────────────────
AUTH_SECRET=your-auth-secret-min-32-chars
AUTH_URL=http://localhost:3000

# OAuth providers (add only the ones you use)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Payment (Stripe) ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Storage (e.g. Uploadthing / S3) ────────────────────────────────────────────
UPLOADTHING_TOKEN=
# -- or S3 compatible --
S3_BUCKET_NAME=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── Email (e.g. Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@lumaspace.io
