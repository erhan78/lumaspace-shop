# Postgres connection string.
# Local Docker default (matches docker-compose.yml):
DATABASE_URL="postgres://lumaspace:lumaspace@localhost:5432/lumaspace"

# Clerk — get these from https://dashboard.clerk.com (Application → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional for local dev — required in production.
# Get this from Clerk dashboard → Webhooks → your endpoint → Signing Secret.
# Without it, /api/webhooks/clerk will reject requests, but the app still
# lazy-creates DB User rows on first authed request (see lib/auth.ts).
CLERK_WEBHOOK_SIGNING_SECRET=
